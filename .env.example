# LPrecast SMTP Configuration
# Copy this file to .env.local and fill in your SMTP credentials

# ===========================================
# SUPABASE (Already configured)
# ===========================================
# Get these from Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://mgjtlmuqsgkhiopwzeni.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===========================================
# APPLICATION
# ===========================================
# Your application URL (for email links)
NEXT_PUBLIC_URL=http://localhost:3000

# ===========================================
# SMTP CONFIGURATION (cPanel Webmail)
# ===========================================
# These will be used by the Supabase Edge Function

# SMTP Host (e.g., mail.yourdomain.com)
SMTP_HOST=mail.lprecast.com

# SMTP Port (587 for TLS, 465 for SSL, 25 for standard)
SMTP_PORT=587

# SMTP Username (usually your full email address)
SMTP_USER=noreply@lprecast.com

# SMTP Password
SMTP_PASS=your_smtp_password

# Email sender identity
SMTP_FROM=noreply@lprecast.com
SMTP_FROM_NAME=LPrecast
SMTP_REPLY_TO=support@lprecast.com
